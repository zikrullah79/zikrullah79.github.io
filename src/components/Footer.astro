<footer id="footer" class="mt-auto relative overflow-hidden border-t border-white/5 bg-dark-bg z-10">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom,_var(--color-dark-card)_0%,_transparent_70%)] opacity-50 z-[-1]"></div>
  
  <div class="px-6 md:px-12 lg:px-24 py-20 flex flex-col items-center justify-center relative">
    <div class="w-full md:w-3/4 lg:w-1/2 text-center animate-fade-in-up">
      <div class="flex justify-center items-center mb-8"> 
        <div class="relative group cursor-pointer">
          <div class="absolute -inset-1 bg-gradient-to-r from-accent-red to-glow-red rounded-full blur opacity-25 group-hover:opacity-75 transition duration-1000 group-hover:duration-200"></div>
          <div class="relative rounded-full flex items-center justify-center bg-dark-card border border-white/10 p-4 w-20 h-20 group-hover:border-accent-red/50 transition-colors duration-500">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-accent-red group-hover:scale-110 group-hover:text-glow-red transition-all duration-300 drop-shadow-[0_0_8px_rgba(225,29,72,0.8)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
          </div>
        </div>
      </div>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-outfit font-bold text-white mb-6 tracking-tight">Now you know about me, <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-red to-glow-red">let's talk about you.</span></h2>
      <p class="text-base md:text-lg text-slate-400 mt-4 max-w-2xl mx-auto leading-relaxed">
        Spill the beans on your plans, dream projects, and what lights your fire! I'm all ears and ready to dive in. Let's turn those awesome ideas into something real and amazing together!
      </p>
    </div>
    
    <div class="hidden lg:flex h-full flex-col gap-4 items-center justify-end absolute right-12 bottom-12 group cursor-pointer" onclick="window.scrollTo({top: 0, behavior: 'smooth'})"> 
      <div class="[writing-mode:vertical-rl] tracking-[0.3em] text-xs font-semibold text-slate-500 uppercase group-hover:text-accent-red transition-colors">Scroll to top</div>
      <div class="bg-gradient-to-t from-accent-red to-transparent h-16 w-0.5 group-hover:h-24 transition-all duration-500 shadow-[0_0_8px_rgba(225,29,72,0.8)]"></div>
    </div>
  </div>
  
  <div class="flex flex-col md:flex-row bg-black/40 border-t border-white/5 text-sm md:text-base px-6 md:px-12 lg:px-24 py-6 text-slate-300 justify-between items-center gap-6 backdrop-blur-sm">
    <div class="hover:text-white transition-colors duration-300">
      <a href="mailto:zikrullahaliwainda@gmail.com" class="flex items-center gap-3">
        <div class="bg-white/10 p-2 rounded-lg">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent-red" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
            <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
          </svg>
        </div>
        zikrullahaliwainda@gmail.com
      </a>
    </div>
    <div class="flex gap-4 md:gap-8 font-medium tracking-wide">
      <a href="https://www.linkedin.com/in/zikrullahali/" target="_blank" class="hover:text-accent-red hover:drop-shadow-[0_0_5px_rgba(225,29,72,0.8)] transition-all duration-300">LinkedIn</a>
      <a href="https://github.com/zikrullah79" target="_blank" class="hover:text-accent-red hover:drop-shadow-[0_0_5px_rgba(225,29,72,0.8)] transition-all duration-300">Github</a>
      <a href="https://wa.me/085255436300" target="_blank" class="hover:text-accent-red hover:drop-shadow-[0_0_5px_rgba(225,29,72,0.8)] transition-all duration-300">Whatsapp</a>
      <a href="https://www.upwork.com/freelancers/~013bec4fd940f1acb9" target="_blank" class="hover:text-accent-red hover:drop-shadow-[0_0_5px_rgba(225,29,72,0.8)] transition-all duration-300">Upwork</a>
    </div>
  </div>
</footer>

<style>
  @keyframes fade-in-up {
    0% {
      opacity: 0;
      transform: translateY(20px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in-up {
    animation: fade-in-up 0.8s ease-out forwards;
  }
</style>
