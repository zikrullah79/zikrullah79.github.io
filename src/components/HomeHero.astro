---
---
<div id="home" class="min-h-[calc(100vh-5rem)] flex items-center justify-center relative px-6 md:px-12 lg:px-24 overflow-hidden">
  <div class="max-w-[1920px] w-full grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 items-center py-12 lg:py-0 relative z-10">
    
    <!-- Text Content -->
    <div class="flex flex-col gap-6 order-2 lg:order-1 animate-[fade-in-right_1s_ease-out]">
      <div class="flex items-center gap-4">
        <div class="h-[2px] w-12 bg-accent-red shadow-[0_0_8px_rgba(225,29,72,0.8)]"></div>
        <p class="font-outfit text-accent-red font-semibold tracking-widest uppercase">Software Engineer</p>
      </div>
      
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-outfit font-extrabold text-white tracking-tight leading-[1.1]">
        Greetings, <br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-slate-500">I am Zik.</span>
      </h1>
      
      <p class="font-inter text-lg md:text-xl text-slate-400 max-w-lg leading-relaxed">
        Your Innovative Software Engineer. Building scalable, high-performance, and visually stunning digital experiences.
      </p>

      <div class="flex items-center gap-6 mt-8">
        <a href="#about" class="px-8 py-4 bg-accent-red hover:bg-glow-red text-white font-medium rounded-lg shadow-[0_0_20px_rgba(225,29,72,0.4)] hover:shadow-[0_0_30px_rgba(225,29,72,0.6)] transition-all transform hover:-translate-y-1">
          Explore My Work
        </a>
        <a href="/services" class="px-8 py-4 bg-transparent border border-white/20 hover:border-white/50 text-white font-medium rounded-lg transition-all hover:bg-white/5">
          My Services
        </a>
      </div>
    </div>

    <!-- Image Content -->
    <div class="relative order-1 lg:order-2 flex justify-center lg:justify-end animate-[fade-in-left_1s_ease-out]">
      
      <!-- Tech Geometric Decor (Replaced Circular Decor) -->
      <!-- Floating Plus 1 -->
      <div class="absolute -top-8 right-12 text-accent-red/60 text-3xl font-light select-none animate-[float_4s_ease-in-out_infinite_alternate] pointer-events-none">+</div>
      <!-- Floating Plus 2 -->
      <div class="absolute bottom-16 -left-8 text-white/20 text-4xl font-light select-none animate-[float_5s_ease-in-out_infinite_alternate_0.5s] pointer-events-none">+</div>
      <!-- Floating Dot Grid -->
      <div class="absolute top-1/4 -right-12 grid grid-cols-3 gap-2 opacity-30 animate-[pulse_4s_cubic-bezier(0.4,0,0.6,1)_infinite] pointer-events-none">
        {Array(9).fill(0).map(() => <div class="w-1.5 h-1.5 rounded-full bg-slate-400"></div>)}
      </div>
      <!-- Accent Line -->
      <div class="absolute -bottom-6 right-20 w-32 h-[2px] bg-gradient-to-r from-transparent via-accent-red/50 to-transparent pointer-events-none"></div>

      <div class="relative w-full max-w-md lg:max-w-lg aspect-[4/5] rounded-3xl overflow-hidden glass-card p-4 group z-10 mx-auto lg:mr-0 inline-block">
        <div class="absolute inset-0 bg-gradient-to-t from-dark-bg via-transparent to-transparent z-10"></div>
        <img src="/assets/img/CV5.png" alt="Zikrullah" class="w-full h-full object-cover object-bottom rounded-2xl grayscale group-hover:grayscale-0 transition-all duration-700" />
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center animate-[bounce_2s_infinite] cursor-pointer group z-20" onclick="document.getElementById('about')?.scrollIntoView({behavior: 'smooth'})">
    <p class="text-xs font-semibold tracking-widest uppercase mb-3 text-slate-500 group-hover:text-accent-red transition-colors">Scroll</p>
    <div class="w-6 h-10 border-2 border-slate-500 group-hover:border-accent-red rounded-full flex justify-center p-1 transition-colors">
      <div class="w-1 h-2 bg-slate-500 group-hover:bg-accent-red rounded-full animate-[pulse_2s_infinite] mt-1"></div>
    </div>
  </div>
</div>

<style>
  @keyframes fade-in-right {
    0% { opacity: 0; transform: translateX(-30px); }
    100% { opacity: 1; transform: translateX(0); }
  }
  @keyframes fade-in-left {
    0% { opacity: 0; transform: translateX(30px); }
    100% { opacity: 1; transform: translateX(0); }
  }
  @keyframes float {
    0% { transform: translateY(0px) rotate(0deg); }
    100% { transform: translateY(-15px) rotate(15deg); }
  }
</style>
