---
const testimonials = [
  {
    name: "Ali Abdul Wahid",
    title: "Top 3% Angular Developers Upwork",
    img: "https://avatars.githubusercontent.com/u/58108579?v=4",
    text: "You must have come across someone who has quite a distinctive way of expressing themselves, but is highly trustworthy when it comes to projects. Zikrullah is probably one of such people. He uses several unusual yet logical communication techniques. However, if you inquire about the work assigned to him, you won't need to be concerned because he will put out his best effort in that task, despite how challenging it may be for him. Zikrullah, it was a joy working with you."
  }
];
---

<div id="testimonials" class="px-6 md:px-12 lg:px-24 py-16 bg-dark-bg flex flex-col items-center justify-center relative border-t border-white/5 overflow-hidden">
  
  <div class="absolute top-1/2 right-0 w-96 h-96 bg-accent-red/5 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>

  <div class="mb-10 text-center animate-[fade-in-up_1s_ease-out_both] z-10 relative">
    <div class="flex items-center gap-4 mb-4 justify-center">
      <div class="h-[2px] w-12 bg-accent-red shadow-[0_0_8px_rgba(225,29,72,0.8)]"></div>
      <span class="text-accent-red font-medium tracking-widest uppercase text-sm">Client Reviews</span>
      <div class="h-[2px] w-12 bg-accent-red shadow-[0_0_8px_rgba(225,29,72,0.8)]"></div>
    </div>
    <h2 class="text-3xl md:text-4xl font-outfit font-bold text-white tracking-tight">What People Say</h2>
  </div>

  <div class="flex w-full md:w-3/4 max-w-[1000px] relative z-10 glass-card p-8 md:p-12 rounded-3xl group hover:border-accent-red/30 transition-colors duration-500">
    <div class="hidden md:flex m-auto opacity-50 hover:opacity-100 transition-opacity">
      <button class="flex items-center justify-center w-12 h-12 bg-white/5 border border-white/10 text-white rounded-full hover:bg-accent-red transition-all duration-300 transform hover:-translate-x-1 focus:outline-none shadow-[0_0_15px_rgba(225,29,72,0)] hover:shadow-[0_0_15px_rgba(225,29,72,0.5)]">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
    </div>
    
    <div class="w-full min-h-[200px] mx-4 md:mx-10 text-center flex flex-col justify-center relative">
      <span class="absolute -top-6 -left-4 text-8xl text-accent-red/20 font-serif leading-none h-8 select-none font-bold">"</span>
      
      <div class="w-full text-base md:text-xl text-slate-300 italic font-light relative z-10">
        <p class="leading-relaxed relative inline-block">
          {testimonials[0].text}
        </p>
        
        <div class="flex flex-col md:flex-row gap-6 mt-12 items-center justify-center pt-8 border-t border-white/10">
          <div class="relative">
            <div class="absolute inset-0 bg-accent-red rounded-full blur opacity-40 group-hover:opacity-80 transition-opacity"></div>
            <img
              src={testimonials[0].img}
              alt={testimonials[0].name}
              class="relative h-16 w-16 aspect-square rounded-full border-2 border-dark-bg object-cover"
            />
          </div>
          <div class="text-center md:text-left">
            <h4 class="text-white font-bold tracking-wide text-lg">{testimonials[0].name}</h4>
            <span class="block text-sm text-accent-red font-medium">{testimonials[0].title}</span>
          </div>
        </div>
      </div>
    </div>

    <div class="hidden md:flex m-auto opacity-50 hover:opacity-100 transition-opacity">
      <button class="flex items-center justify-center w-12 h-12 bg-white/5 border border-white/10 text-white rounded-full hover:bg-accent-red transition-all duration-300 transform hover:translate-x-1 focus:outline-none shadow-[0_0_15px_rgba(225,29,72,0)] hover:shadow-[0_0_15px_rgba(225,29,72,0.5)]">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
  </div>
</div>
