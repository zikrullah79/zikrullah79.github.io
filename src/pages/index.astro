---
import Layout from '../layouts/Layout.astro';
import HomeHero from '../components/HomeHero.astro';
import Career from '../components/Career.astro';
import Portfolio from '../components/Portfolio.astro';
import Testimonials from '../components/Testimonials.astro';
import { getCollection } from 'astro:content';

const blogs = await getCollection('blogs');
const latestBlogs = blogs
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Layout title="Zikrullah - Software Engineer">
  <HomeHero />
  <Career />
  
  <div class="py-24 px-6 md:px-12 lg:px-24 border-t border-white/5 relative z-10">
    <div class="max-w-[1920px] mx-auto hidden lg:block absolute left-0 top-0 w-1/3 h-full bg-[radial-gradient(ellipse_at_left,_var(--color-dark-card)_0%,_transparent_70%)] opacity-30 z-0 pointer-events-none"></div>
    <div class="max-w-[1920px] mx-auto relative z-10">
      
      <div class="flex items-center gap-4 mb-4 justify-center">
        <div class="h-[2px] w-12 bg-accent-red shadow-[0_0_8px_rgba(225,29,72,0.8)]"></div>
        <span class="text-accent-red font-medium tracking-widest uppercase text-sm">Insights</span>
        <div class="h-[2px] w-12 bg-accent-red shadow-[0_0_8px_rgba(225,29,72,0.8)]"></div>
      </div>
      <h2 class="text-4xl md:text-5xl font-outfit font-bold text-white mb-12 text-center tracking-tight">Latest Articles</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {latestBlogs.map((blog) => (
          <a href={`/blogs/${blog.id}`} class="group glass-card p-8 rounded-3xl transition-all duration-300 flex flex-col h-full hover:-translate-y-2 hover:border-accent-red/30 hover:shadow-[0_10px_30px_rgba(225,29,72,0.1)] relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-accent-red/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            
            <div class="mb-4 text-xs font-bold text-accent-red tracking-widest uppercase">
              {new Date(blog.data.pubDate).toLocaleDateString('en-US', {
                year: 'numeric', month: 'short', day: 'numeric'
              })}
            </div>
            <h3 class="text-2xl font-bold text-white mb-4 group-hover:text-accent-red transition-colors relative z-10">{blog.data.title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed flex-grow relative z-10">
              {blog.data.description}
            </p>
            <div class="mt-8 font-medium text-sm text-accent-red flex items-center gap-2 group-hover:gap-3 transition-all relative z-10">
              Read more <span class="bg-accent-red/20 text-accent-red p-1 rounded-full group-hover:bg-accent-red group-hover:text-white transition-colors">→</span>
            </div>
          </a>
        ))}
      </div>
      
      <div class="mt-16 text-center">
        <a href="/blogs" class="inline-block border border-accent-red/50 text-accent-red px-8 py-3 rounded-full font-medium hover:bg-accent-red hover:text-white transition-all duration-300 shadow-[0_0_15px_rgba(225,29,72,0.2)] hover:shadow-[0_0_25px_rgba(225,29,72,0.6)]">
          View All Blogs
        </a>
      </div>
      
    </div>
  </div>

  <Portfolio />
  <Testimonials />
</Layout>
