---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allBlogs = await getCollection('blogs');
const formattedBlogs = allBlogs.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTil = await getCollection('til');
const formattedTil = allTil.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blogs & TIL - Zikrullah" hideFooter={true}>
  <div class="bg-dark-bg min-h-[85vh] py-24 px-6 md:px-12 lg:px-24 border-t border-white/5 relative">
    
    <div class="absolute top-0 right-0 w-full h-96 bg-gradient-to-b from-accent-red/5 to-transparent pointer-events-none z-0"></div>

    <div class="max-w-[1920px] mx-auto text-center mb-20 animate-[fade-in-up_1s_ease-out_both] pt-[20px] relative z-10">
      <h1 class="text-5xl md:text-7xl font-outfit font-bold text-white mb-6">Technical <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-red to-glow-red">Logs</span></h1>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">Observations, deep dives, and daily learnings from my journey as a Software Engineer.</p>
    </div>

    <div class="max-w-[1920px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-12 relative z-10">
      
      <!-- Blogs Column -->
      <div class="animate-[fade-in-right_1s_ease-out_both_0.2s]">
        <div class="flex items-center gap-4 mb-10">
          <div class="w-10 h-10 rounded-xl bg-dark-card border border-white/10 flex items-center justify-center text-accent-red shadow-inner shadow-white/5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M2 5a2 2 0 012-2h8a2 2 0 012 2v10a2 2 0 002 2H4a2 2 0 01-2-2V5zm3 1h6v2H5V6zm6 5H5v2h6v-2z" clip-rule="evenodd" />
            </svg>
          </div>
          <h2 class="text-3xl font-outfit font-bold text-white tracking-wide">Long-Form Articles</h2>
        </div>
        
        <div class="flex flex-col gap-6">
          {formattedBlogs.map((post) => (
            <a href={`/blogs/${post.id}`} class="group glass-card p-8 rounded-3xl transition-all duration-300 relative overflow-hidden flex flex-col items-start hover:-translate-y-1 hover:shadow-[0_10px_20px_rgba(225,29,72,0.1)] hover:border-accent-red/30">
              <div class="absolute top-0 left-0 w-1 h-full bg-accent-red opacity-0 group-hover:opacity-100 transition-opacity drop-shadow-[0_0_8px_rgba(225,29,72,0.8)]"></div>
              
              <div class="flex items-center justify-between w-full mb-4">
                <span class="text-xs font-bold text-accent-red bg-accent-red/10 border border-accent-red/20 px-3 py-1 rounded-full uppercase tracking-widest">
                  {new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </span>
                {post.data.tags && post.data.tags.length > 0 && (
                   <span class="text-xs text-slate-400 font-medium px-3 py-1 bg-white/5 rounded-full border border-white/10">{post.data.tags[0]}</span>
                )}
              </div>
              
              <h3 class="text-2xl font-bold text-white mb-3 group-hover:text-accent-red transition-colors">{post.data.title}</h3>
              <p class="text-slate-400 text-sm leading-relaxed max-w-prose mb-6">{post.data.description}</p>
              
              <span class="text-sm font-medium text-accent-red mt-auto flex items-center gap-2 group-hover:gap-3 transition-all">
                Read Post 
                <span class="bg-accent-red/20 p-1 rounded-full group-hover:bg-accent-red group-hover:text-white transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7-7m7 7H3" /></svg>
                </span>
              </span>
            </a>
          ))}
          {formattedBlogs.length === 0 && <p class="text-slate-500 italic glass-card p-6 rounded-2xl text-center">More articles coming soon.</p>}
        </div>
      </div>

      <!-- TIL Column -->
      <div class="animate-[fade-in-left_1s_ease-out_both_0.4s]">
        <div class="flex items-center gap-4 mb-10">
          <div class="w-10 h-10 rounded-xl bg-dark-card border border-white/10 flex items-center justify-center text-slate-300 shadow-inner shadow-white/5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h2 class="text-3xl font-outfit font-bold text-white tracking-wide">Today I Learned</h2>
        </div>
        
        <div class="flex flex-col gap-6 relative before:absolute before:inset-0 before:ml-[1.375rem] md:before:mx-auto md:before:translate-x-0 before:h-full before:w-[2px] before:bg-white/10">
          
          {formattedTil.map((post) => (
            <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group">
              <!-- Timeline Marker -->
              <div class="flex items-center justify-center w-12 h-12 rounded-full glass-card shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 z-10 transition-all duration-300 group-hover:border-accent-red group-hover:shadow-[0_0_15px_rgba(225,29,72,0.4)]">
                <div class="w-3 h-3 bg-slate-500 rounded-full group-hover:bg-accent-red transition-colors shadow-[0_0_8px_rgba(225,29,72,0)] group-hover:shadow-[0_0_8px_rgba(225,29,72,0.8)]"></div>
              </div>
              
              <!-- Content Card -->
              <div class="w-[calc(100%-4rem)] md:w-[calc(50%-2rem)] p-6 rounded-3xl glass-card transition-all duration-300 group-hover:border-accent-red/30 hover:-translate-y-1 hover:shadow-[0_5px_15px_rgba(0,0,0,0.3)]">
                <a href={`/til/${post.id}`} class="block">
                  <div class="flex items-baseline justify-between mb-3">
                    <h3 class="text-xl font-bold text-white group-hover:text-accent-red transition-colors leading-tight">{post.data.title}</h3>
                  </div>
                  <div class="flex items-center justify-between mt-4 pb-2 border-b border-white/5">
                     <span class="text-xs font-medium text-slate-400">
                      {new Date(post.data.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                     </span>
                     {post.data.tags && post.data.tags.length > 0 && (
                       <span class="text-xs text-accent-red font-medium px-2 py-0.5 bg-accent-red/10 rounded-md border border-accent-red/20">{post.data.tags[0]}</span>
                     )}
                  </div>
                </a>
              </div>
            </div>
          ))}
          {formattedTil.length === 0 && <p class="text-slate-500 italic pl-14 md:pl-0 md:text-center mt-4">More quick learnings on the way.</p>}

        </div>
      </div>

    </div>
  </div>
</Layout>

<style>
  @keyframes fade-in-up {
    0% { opacity: 0; transform: translateY(30px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  @keyframes fade-in-right {
     0% { opacity: 0; transform: translateX(-30px); }
    100% { opacity: 1; transform: translateX(0); }
  }
  @keyframes fade-in-left {
     0% { opacity: 0; transform: translateX(30px); }
    100% { opacity: 1; transform: translateX(0); }
  }
</style>
