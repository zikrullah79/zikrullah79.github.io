---
import Layout from '../layouts/Layout.astro';
import Portfolio from '../components/Portfolio.astro';
---

<Layout title="Services - Zikrullah" hideFooter={true}>
  <!-- Service Hero -->
  <div class="pt-32 pb-24 px-6 md:px-12 lg:px-24 bg-dark-bg min-h-[50vh] flex flex-col justify-center items-center text-center relative overflow-hidden border-b border-white/5">
    
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-3xl aspect-video bg-accent-red/10 blur-[120px] rounded-full pointer-events-none z-0"></div>
    
    <div class="relative z-10 animate-[fade-in-up_1s_ease-out_both] flex flex-col items-center max-w-[1920px] mx-auto">
      <div class="flex items-center gap-4 mb-6 justify-center">
        <div class="h-[2px] w-12 bg-accent-red shadow-[0_0_8px_rgba(225,29,72,0.8)]"></div>
        <span class="text-accent-red font-medium tracking-widest uppercase text-sm">Capabilities</span>
        <div class="h-[2px] w-12 bg-accent-red shadow-[0_0_8px_rgba(225,29,72,0.8)]"></div>
      </div>
      
      <h1 class="text-5xl md:text-7xl font-outfit font-extrabold mb-6 tracking-tight text-white leading-tight">
        My Expertise & <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-red to-glow-red">Services</span>
      </h1>
      <p class="text-lg md:text-xl max-w-2xl text-slate-400 font-light leading-relaxed">
        I engineer tailored, high-performance solutions designed to elevate your business. From robust web infrastructures to cutting-edge AI integrations, let's build the future together.
      </p>
    </div>
  </div>

  <!-- Services Grid -->
  <div class="py-24 px-6 md:px-12 lg:px-24 bg-dark-bg relative">
    <div class="max-w-[1920px] mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 relative z-10">
      
      <!-- Service 1 -->
      <div class="glass-card rounded-3xl p-10 hover:-translate-y-2 hover:border-accent-red/40 transition-all duration-300 group shadow-lg hover:shadow-[0_10px_30px_rgba(225,29,72,0.15)] relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-accent-red/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        
        <div class="w-16 h-16 bg-dark-bg border border-white/10 text-accent-red rounded-2xl flex items-center justify-center mb-8 group-hover:scale-110 group-hover:border-accent-red/50 transition-all duration-300 shadow-inner relative z-10">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 drop-shadow-[0_0_8px_rgba(225,29,72,0.8)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-4 group-hover:text-accent-red transition-colors relative z-10">Website Development</h3>
        <p class="text-slate-400 leading-relaxed relative z-10">
          Crafting modern, responsive, and blazing-fast web applications. Ranging from corporate landing pages to complex admin dashboards and e-commerce platforms.
        </p>
      </div>

      <!-- Service 2 -->
      <div class="glass-card rounded-3xl p-10 hover:-translate-y-2 hover:border-accent-red/40 transition-all duration-300 group shadow-lg hover:shadow-[0_10px_30px_rgba(225,29,72,0.15)] relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-accent-red/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        
        <div class="w-16 h-16 bg-dark-bg border border-white/10 text-accent-red rounded-2xl flex items-center justify-center mb-8 group-hover:scale-110 group-hover:border-accent-red/50 transition-all duration-300 shadow-inner relative z-10">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 drop-shadow-[0_0_8px_rgba(225,29,72,0.8)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-4 group-hover:text-accent-red transition-colors relative z-10">Application Development</h3>
        <p class="text-slate-400 leading-relaxed relative z-10">
          Building high-quality applications at an accelerated pace by leveraging advanced AI tools and workflows. Delivering robust solutions faster without compromising on precision or performance.
        </p>
      </div>

      <!-- Service 3 -->
      <div class="glass-card rounded-3xl p-10 hover:-translate-y-2 hover:border-accent-red/40 transition-all duration-300 group shadow-lg hover:shadow-[0_10px_30px_rgba(225,29,72,0.15)] relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-accent-red/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        
        <div class="w-16 h-16 bg-dark-bg border border-white/10 text-accent-red rounded-2xl flex items-center justify-center mb-8 group-hover:scale-110 group-hover:border-accent-red/50 transition-all duration-300 shadow-inner relative z-10">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 drop-shadow-[0_0_8px_rgba(225,29,72,0.8)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-4 group-hover:text-accent-red transition-colors relative z-10">Bug Tracing & Fixes</h3>
        <p class="text-slate-400 leading-relaxed relative z-10">
          Deep-dive debugging, performance optimization, and resolving critical issues across full-stack environments. Bringing stability back to chaotic codebases.
        </p>
      </div>

    </div>
  </div>

  <!-- Our Works -->
  <Portfolio />

  <!-- Contact Us (Web3Forms) -->
  <div class="py-24 px-6 md:px-12 lg:px-24 bg-dark-bg relative border-t border-white/5">
    
    <div class="absolute right-0 bottom-0 w-1/2 h-1/2 bg-[radial-gradient(ellipse_at_bottom_right,_var(--color-dark-card)_0%,_transparent_70%)] opacity-40 z-0 pointer-events-none"></div>

    <div class="max-w-4xl mx-auto glass-card rounded-[2rem] p-8 md:p-14 relative z-10">
      
      <!-- Decorative element -->
      <div class="absolute -top-6 -right-6 w-24 h-24 bg-accent-red/20 border border-accent-red/30 rounded-full blur-xl pointer-events-none"></div>
      
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-outfit font-bold text-white mb-4">Let's Work <span class="text-accent-red">Together</span></h2>
        <p class="text-slate-400 text-lg">Leave me a message and I'll get back to you as soon as possible.</p>
      </div>

      <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="flex flex-col gap-6">
        <input type="hidden" name="access_key" value="3a90be2a-bfa6-4777-9b08-03e26225a18d" />
        
        <div class="flex flex-col md:flex-row gap-6">
          <div class="flex-1 flex flex-col gap-2">
            <label for="name" class="font-medium text-slate-300 text-sm tracking-wide uppercase">Name</label>
            <input type="text" id="name" name="name" required placeholder="John Doe" class="px-5 py-4 bg-dark-bg/50 border border-white/10 rounded-xl text-white placeholder-slate-600 focus:outline-none focus:ring-1 focus:ring-accent-red focus:border-accent-red transition-all" />
          </div>
          <div class="flex-1 flex flex-col gap-2">
            <label for="email" class="font-medium text-slate-300 text-sm tracking-wide uppercase">Email Address</label>
            <input type="email" id="email" name="email" required placeholder="john@example.com" class="px-5 py-4 bg-dark-bg/50 border border-white/10 rounded-xl text-white placeholder-slate-600 focus:outline-none focus:ring-1 focus:ring-accent-red focus:border-accent-red transition-all" />
          </div>
        </div>

        <div class="flex flex-col gap-2">
          <label for="message" class="font-medium text-slate-300 text-sm tracking-wide uppercase">Message</label>
          <textarea id="message" name="message" rows="5" required placeholder="Tell me about your project..." class="px-5 py-4 bg-dark-bg/50 border border-white/10 rounded-xl text-white placeholder-slate-600 focus:outline-none focus:ring-1 focus:ring-accent-red focus:border-accent-red transition-all resize-none"></textarea>
        </div>
        
        <!-- Honeypot Spam Protection -->
        <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

        <button type="submit" id="submit-btn" class="mt-8 bg-accent-red hover:bg-glow-red text-white font-semibold tracking-wide px-10 py-4 w-full rounded-xl shadow-[0_0_15px_rgba(225,29,72,0.4)] hover:shadow-[0_0_25px_rgba(225,29,72,0.6)] transform hover:-translate-y-1 transition-all duration-300 flex items-center justify-center gap-2">
          <span>Send Message</span>
        </button>
      </form>
    </div>
  </div>
</Layout>

<script>
  function setupForm() {
    const form = document.getElementById('contact-form');
    const btn = document.getElementById('submit-btn');
    const btnText = btn?.querySelector('span');

    if (form) {
      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        if (btn && btnText) {
          btn.disabled = true;
          btnText.innerText = 'Sending...';
          btn.classList.add('opacity-70', 'cursor-not-allowed');
        }

        const formData = new FormData(form);
        const object = Object.fromEntries(formData.entries());
        const json = JSON.stringify(object);

        try {
          const response = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            },
            body: json
          });
          
          const result = await response.json();
          
          if (response.status === 200) {
            if (window.showToast) window.showToast('Message sent successfully! I will get back to you soon.', 'success');
            form.reset();
          } else {
            console.log(result);
            if (window.showToast) window.showToast(result.message || 'Something went wrong. Please try again.', 'error');
          }
        } catch (error) {
          console.error(error);
          if (window.showToast) window.showToast('Failed to send message. Please check your connection.', 'error');
        } finally {
          if (btn && btnText) {
            btn.disabled = false;
            btnText.innerText = 'Send Message';
            btn.classList.remove('opacity-70', 'cursor-not-allowed');
          }
        }
      });
    }
  }

  // Setup on initial load
  setupForm();
  
  // Setup if using view transitions
  document.addEventListener('astro:page-load', setupForm);
</script>

<style>
  @keyframes fade-in-up {
    0% { opacity: 0; transform: translateY(30px); }
    100% { opacity: 1; transform: translateY(0); }
  }
</style>
